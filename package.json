{
  "name": "playwright-api-logger",
  "version": "2.3.0",
  "description": "Comprehensive API request/response logger with curl export for Playwright tests",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./reporter": {
      "types": "./dist/reporter.d.ts",
      "default": "./dist/reporter.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npx playwright test",
    "test:demo": "API_LOGS=true npx playwright test tests/demo-log.spec.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "playwright",
    "api",
    "logger",
    "curl",
    "testing",
    "postman",
    "form-data",
    "multipart",
    "reporter"
  ],
  "author": "AZANIR",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AZANIR/playwright-api-logger.git"
  },
  "bugs": {
    "url": "https://github.com/AZANIR/playwright-api-logger/issues"
  },
  "homepage": "https://github.com/AZANIR/playwright-api-logger#readme",
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/node": "^25.5.0",
    "typescript": "^5.0.0"
  }
}
